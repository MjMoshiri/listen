{
  "manifest_version": 3,
  "name": "Listen - O'Reilly Chapter Capture",
  "version": "0.1.0",
  "description": "Select chapters from an O'Reilly book and send them to the local Listen app for audio conversion.",
  "host_permissions": ["http://localhost:3000/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": [
        "https://learning.oreilly.com/library/view/*",
        "https://learning-oreilly-com.ezproxy.sfpl.org/library/view/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
